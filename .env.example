# ============================================
# CONFIGURAÇÃO DO PROJETO RAG MULTIMODAL
# ============================================
# Copie este arquivo para .env e preencha
# com suas chaves reais:
#   copy .env.example .env
# ============================================

# --- Google Gemini ---
GEMINI_API_KEY=

# --- Pinecone ---
PINECONE_API_KEY=
PINECONE_INDEX_NAME=rag-multimodal
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# --- Modelo de Embedding ---
EMBEDDING_MODEL=gemini-embedding-2-preview
EMBEDDING_DIMENSIONS=1536
